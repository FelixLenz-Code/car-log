# --- Database ---
# When running via docker-compose, host = "db" (the service name).
DATABASE_URL="postgresql://carlog:change-me-db-password@db:5432/carlog?schema=public"

# Postgres container credentials (used by docker-compose to init the DB)
POSTGRES_USER="carlog"
POSTGRES_PASSWORD="change-me-db-password"
POSTGRES_DB="carlog"

# --- Auth ---
# Long random string used to derive/sign session data. Generate with:
#   openssl rand -base64 48
SESSION_SECRET="change-me-to-a-long-random-string"

# First admin account, created automatically on first start (seed).
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me-admin-password"
ADMIN_NAME="Administrator"

# --- App ---
# Set to "true" in production (behind HTTPS) so the session cookie is Secure.
COOKIE_SECURE="false"
NODE_ENV="production"

# Host port the app is published on (container always listens on 3000).
APP_PORT="3000"
